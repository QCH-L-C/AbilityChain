{
  "whitelist": {
    "allowed": [
      "index.html",
      "README.md",
      "LICENSE.md",
      "registry.json",
      "whitelist.json",
      "genesis-block.json",
      "package.json",

      "runtime.js",
      "start.js",
      "server.js",
      "linked-hash.js",
      ".github/workflows/ci.yml",

      "global/auth.js",
      "global/popup.html",
      "global/quadruplex-engine.js",

      "wallet/index.html",
      "wallet/pzqqet-0_standard.js",

      "chain/explorer/index.html",

      "settings/index.html"
    ],
    "licenseRequired": "REL-v1.0",
    "hashAlgorithm": "sha256",
    "rules": {
      "noOverwrite": true,
      "noModifyOriginalFiles": true,
      "forksMayAddOnly": ["sub/", "deep/"]
    }
  }
}
